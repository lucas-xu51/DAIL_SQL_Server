# DAIL-SQL 环境配置

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here

# 数据库路径配置
DATABASE_DIR=./dataset/spider/database
DATASET_DIR=./dataset

# 服务器配置
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# LLM默认配置
DEFAULT_MODEL=gpt-4
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_RETRIES=3
DEFAULT_K_SHOT=9

# 缓存配置（可选）
REDIS_URL=redis://localhost:6379
ENABLE_CACHE=False

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
